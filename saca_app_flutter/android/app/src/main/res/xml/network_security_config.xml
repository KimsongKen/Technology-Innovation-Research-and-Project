<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext HTTP for local FastAPI testing (e.g. http://192.168.x.x:8000). -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
